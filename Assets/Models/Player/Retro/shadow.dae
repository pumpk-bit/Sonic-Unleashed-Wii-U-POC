    <unit name="meter" meter="1"/>
    <up_axis>Z_UP</up_axis>
  </asset>
  <library_effects>
    <effect id="Shadow-effect">
      <profile_COMMON>
        <newparam sid="shadow_png-surface">
          <surface type="2D">
            <init_from>shadow_png</init_from>
          </surface>
        </newparam>
        <newparam sid="shadow_png-sampler">
          <sampler2D>
            <source>shadow_png-surface</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <lambert>
            <emission>
              <color sid="emission">0 0 0 1</color>
            </emission>
            <diffuse>
              <texture texture="shadow_png-sampler" texcoord="UVSet0"/>
            </diffuse>
            <index_of_refraction>
              <float sid="ior">1</float>
            </index_of_refraction>
          </lambert>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_images>
    <image id="shadow_png" name="shadow_png">
      <init_from>shadow.png</init_from>
    </image>
  </library_images>
  <library_materials>
    <material id="Shadow-material" name="Shadow">
      <instance_effect url="#Shadow-effect"/>
    </material>
  </library_materials>
