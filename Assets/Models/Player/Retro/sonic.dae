    <effect id="Blue-effect">
      <profile_COMMON>
        <newparam sid="Blue_png-surface">
          <surface type="2D">
            <init_from>Blue_png</init_from>
          </surface>
        </newparam>
        <newparam sid="Blue_png-sampler">
          <sampler2D>
